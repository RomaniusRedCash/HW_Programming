map 800 800
start 50 50
end 750 750

# Монолитная разделительная стена по центру диагонали
b 200 350 400 100

# Дополнительные блоки, которые делают один из путей (например, нижний) более извилистым
# Верхний коридор (чистый)
b 350 150 80 40

# Нижний коридор (заставлен препятствиями)
b 220 550 50 120
b 450 500 60 60
b 550 620 100 40
