map 800 800
start 50 50
end 750 750

# Огромное U-образное препятствие прямо по центру
# Левая стена ловушки
b 250 200 40 400
# Дно ловушки (закрывает прямой путь)
b 250 600 340 40
# Правая стена ловушки
b 550 200 40 400

# Маленькие отдельно стоящие блоки, чтобы усложнить обход снаружи
b 100 300 50 50
b 680 450 50 50
