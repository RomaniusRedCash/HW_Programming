{
    "name": "Compressor",
    "files": [
        {
            "recursive": true,
            "filters": ["*.cpp", "*.hpp", "*.cxx", "*.cc", "*.h", "Makefile"]
        }
    ],
    "build": {
        "directory": ".",
        "targets": [
            {
                "name": "Собрать DEBUG",
                "build_cmd": "make -j12 debug"
            },
            {
                "name": "Собрать",
                "build_cmd": "make -j12 release"
            },
            {
                "name": "Очистка",
                "build_cmd": "make clean"
            }
        ],
        "default_target": "Собрать"
    }
}
